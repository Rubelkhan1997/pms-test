{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "jsx": "preserve",
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "lib": ["ES2022", "DOM"],
        "types": ["vite/client"],
        "paths": {
            "@/*": ["./resources/js/*"]
        },
        "baseUrl": ".",
        "skipLibCheck": true
    },
    "include": ["resources/js/**/*.ts", "resources/js/**/*.d.ts", "resources/js/**/*.vue"],
    "exclude": ["node_modules"]
}
